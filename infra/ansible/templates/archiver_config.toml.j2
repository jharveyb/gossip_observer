# Gossip Archiver Configuration
# UUID is set via ARCHIVER_UUID environment variable in systemd

# Database connection URL
# Can also be set via ARCHIVER_DB_URL environment variable
# Format: postgresql://user:password@host:port/database
db_url = "{{ archiver_db_urls[item.uuid] }}"

[nats]
server_addr = "{{ item.nats_server }}"
subject_prefix = "observer.*"

[console]
listen_addr = "{{ tailscale_ip }}"
listen_port = {{ item.console_port | default(6670) }}
retention_secs = 120

[database]
# Maximum number of items to write to DB at once
batch_size = {{ archiver_db_batch_size | default(2500) }}

# Seconds between unconditional DB flushes
flush_interval = {{ archiver_db_flush_interval | default(2) }}

[export]
# Parquet export subsystem. Should only be true once message_first_seen table
# is populated in the DB.
enabled = {{ item.export_enabled | default(false) | lower }}

{% if item.export_dir is defined %}
# Output + DuckDB temp-spill location. Set per-instance to a roomy non-root
# volume: both the Parquet files and the duckdb_tmp spill directory live here.
# Omit to fall back to the binary default of {storage_dir}/exports.
dir = "{{ item.export_dir }}"
{% endif %}

# DuckDB buffer memory limit (MB). Conservative on this 8 GB VPS, which also
# runs Postgres and (potentially) the other archiver instance's DuckDB. Past
# this limit DuckDB spills to dir/duckdb_tmp instead of OOMing.
soft_memory_limit = {{ item.export_soft_memory_limit | default(1024) }}
threads = {{ item.export_threads | default(2) }}

# --- Data retention: drop old timings chunks after verifying their export ---
# Both flags default safe. deletion never happens unless deletion_enabled=true,
# dry_run=false, AND the read-only S3 creds are provided.
deletion_enabled = {{ item.deletion_enabled | default(false) | lower }}
deletion_dry_run = {{ item.deletion_dry_run | default(true) | lower }}
retention_after_days = {{ item.retention_after_days | default(45) }}
# Garage S3 endpoint for verification reads: the Garage host's tailscale name +
# Caddy port (plain HTTP over tailscale). Caddy already binds the tailscale IP.
verify_endpoint = "{{ item.verify_endpoint | default('') }}"
# SSL needed if we use public HTTPS domain
verify_use_ssl = {{ item.verify_use_ssl | default(false) | lower }}
verify_bucket = "{{ item.verify_bucket | default('gossip-observer-data') }}"
verify_region = "{{ item.verify_region | default('garage') }}"
{% if archiver_verify_s3_keys is defined and item.uuid in archiver_verify_s3_keys %}
# Read-only Garage S3 creds for the retention verify pass, from vault. Keyed by
# instance UUID (same pattern as archiver_db_urls) so staging and prod get
# distinct read-only keys. Same treatment as the db_url password above (this file
# already holds it). A missing entry leaves the creds unset, disabling deletion
# regardless of the flags.
verify_access_key_id = "{{ archiver_verify_s3_keys[item.uuid].key_id }}"
verify_secret_access_key = "{{ archiver_verify_s3_keys[item.uuid].secret }}"
{% endif %}

{# Admin API is left at its default bind (127.0.0.1:2019). `caddy reload`
   — triggered by `systemctl reload caddy` — posts to that endpoint to
   hot-swap config, so disabling it would make every reload error with
   "connection refused on :2019". Localhost-only by default, so not a
   public exposure. #}

{# Caddy listens on loopback only. Public traffic reaches us via Cloudflare
   Tunnel (cloudflared) → Caddy → Garage. TLS is terminated at Cloudflare's
   edge, so Caddy speaks plain HTTP on the loopback. The S3 SigV4 signature
   in each request is verified by Garage downstream — Cloudflare and Caddy
   are pure transit and don't see the auth credentials in any usable form.

   Site address is `:port` (no host) plus an explicit `bind 127.0.0.1`:
   - `:port` (no host) matches any Host header the client sent — required
     because cloudflared forwards requests with the public hostname
     (e.g. `data.example.com`) in the Host header, not `localhost`.
   - `bind 127.0.0.1` constrains the listening interface to loopback.

   Caveat: `localhost:port` or `http://localhost:port` would also serve
   plain HTTP on loopback, BUT would constrain Caddy's Host matching to
   `localhost`, so cloudflared traffic would fall through to a no-handler
   state (visible as "NOP" log entries with status=0 / empty response). #}
:{{ caddy_public_port }} {
	bind localhost
	# Transparent reverse proxy: do NOT rewrite the Host header — AWS SigV4
	# includes it in the signature, so any rewrite causes signature
	# mismatches on signed S3 requests.
	reverse_proxy {{ caddy_garage_upstream }} {
		# Parquet range requests and large file streams shouldn't be buffered.
		flush_interval -1
{% if caddy_health_check_upstream is defined %}
		health_uri /health
		health_port {{ caddy_health_check_upstream.split(':')[1] | default(3903) }}
{% endif %}
	}

	# S3 uploads can be large; set a reasonable limit.
	request_body {
		max_size {{ caddy_max_request_size }}
	}

	# Access log goes to stderr; systemd routes that to journald. Tail with
	# `journalctl -u caddy`. Rotation is handled by journald's own size caps
	# (SystemMaxUse etc. in journald.conf) — avoids file-writer permission
	# issues and matches how other services in this repo log.
	log {
		format json
	}
}
